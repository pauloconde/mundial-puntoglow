              </svg>
            </a>
            <a href={sponsorInfo.whatsapp} target="_blank" rel="noopener" aria-label="WhatsApp" 
               class="w-14 h-14 rounded-full flex items-center justify-center transition-colors"
               style="background: rgba(255,255,255,0.08); color: var(--brand-nav-icon-active, #f59e0b);">
              <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </a>
          </div>
        </div>
        
        <div class="space-y-6 mt-4">
          <!-- Botón instalar Android -->
          <div id="install-android" style="display:none;" class="px-2">
            <p class="text-[10px] font-semibold uppercase tracking-wider text-gray-500 mb-3 text-center">Instalar app</p>
            <button id="install-btn"
                    class="w-full flex items-center justify-center gap-2 px-6 py-3.5 rounded-2xl font-semibold text-sm transition-transform active:scale-95 hover:opacity-90"
                    style="background: var(--brand-nav-icon-active, #f59e0b); color: #fff; box-shadow: 0 4px 14px rgba(0,0,0,0.15);">
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
              Instalar en Android
            </button>
          </div>

          <!-- Guía instalar iOS -->
          <div id="install-ios" style="display:none;" class="px-2">
            <p class="text-[10px] font-semibold uppercase tracking-wider text-gray-500 mb-2">Instalar en iPhone</p>
            <div class="rounded-2xl p-4 space-y-3 text-sm" style="background: rgba(0,0,0,0.2);">
              <div class="flex items-start gap-3">
                <span class="text-xl shrink-0">1️⃣</span>
                <p style="color: var(--brand-nav-text, #d1d5db);">Toca el botón <strong>Compartir</strong> <span class="inline-block">&#x1F4E4;</span> en Safari</p>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-xl shrink-0">2️⃣</span>
                <p style="color: var(--brand-nav-text, #d1d5db);">Selecciona <strong>“Añadir a inicio”</strong></p>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-xl shrink-0">3️⃣</span>
                <p style="color: var(--brand-nav-text, #d1d5db);">Toca <strong>“Añadir”</strong> en la esquina superior derecha</p>
              </div>
            </div>
          </div>
        </div>

        <hr class="border-t border-[var(--border-subtle)] my-2 opacity-50" />

        <nav class="flex flex-col gap-2 px-2" style="color: var(--brand-app-bg, #053332);">
          <a href="/" class={`flex items-center gap-4 px-4 py-3 rounded-2xl transition-colors ${page === 'home' ? 'bg-black/5 text-[var(--brand-nav-icon-active,#f59e0b)]' : 'hover:bg-black/5'}`}>
            <svg class="w-6 h-6 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            <span class="font-semibold text-sm">Inicio</span>
          </a>
          
          <a href="/grupos" class={`flex items-center gap-4 px-4 py-3 rounded-2xl transition-colors ${page === 'grupos' ? 'bg-black/5 text-[var(--brand-nav-icon-active,#f59e0b)]' : 'hover:bg-black/5'}`}>
            <svg class="w-6 h-6 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M3 14h18M10 3v18M14 3v18" />
            </svg>
            <span class="font-semibold text-sm">Grupos</span>
          </a>
          
          <a href="/estadios" class={`flex items-center gap-4 px-4 py-3 rounded-2xl transition-colors ${page === 'estadios' ? 'bg-black/5 text-[var(--brand-nav-icon-active,#f59e0b)]' : 'hover:bg-black/5'}`}>
            <svg class="w-6 h-6 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="font-semibold text-sm">Estadios</span>
          </a>
          
          <a href="/calendario" class={`flex items-center gap-4 px-4 py-3 rounded-2xl transition-colors ${page === 'calendario' ? 'bg-black/5 text-[var(--brand-nav-icon-active,#f59e0b)]' : 'hover:bg-black/5'}`}>
            <svg class="w-6 h-6 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2" stroke-linecap="round" stroke-linejoin="round"/>
              <line x1="16" y1="2" x2="16" y2="6" stroke-linecap="round"/>
              <line x1="8" y1="2" x2="8" y2="6" stroke-linecap="round"/>
              <line x1="3" y1="10" x2="21" y2="10" stroke-linecap="round"/>
            </svg>
            <span class="font-semibold text-sm">Calendario</span>
          </a>
        </nav>

      </div>

      <!-- Footer del drawer -->
      <div class="px-5 py-1 pb-4">
        <p class="text-[11px] text-center text-gray-400 relative z-10">
          Desarrollado para <a href={sponsorInfo.website} target="_blank" rel="noopener" class="text-white font-semibold hover:underline" style="color: var(--brand-nav-icon-active, #f59e0b);">{sponsorInfo.name}</a> por
        </p>
        <div class="flex justify-center items-center -mt-14 -mb-10 relative z-0">
          <a href="https://pauloconde.dev" target="_blank" rel="noopener" class="hover:opacity-80 transition-opacity">
            <img src="/paulocondedev.png" alt="pauloconde.dev" class="h-48 w-auto object-contain" />
          </a>
        </div>
      </div>
    </aside>

    <!-- ── Main Content ── -->
    <main class="pt-14 min-h-screen">
      <slot />
    </main>

    <!-- ── Script: Detección de partido en vivo ── -->
    <script define:vars={{ kickoffISOs }}>
      (function () {
        var MATCH_DURATION_MS = 110 * 60 * 1000; // 110 minutos

        function checkLive() {
          var now = Date.now();
          var isLive = kickoffISOs.some(function (iso) {
            var kick = new Date(iso).getTime();
            return now >= kick && now <= kick + MATCH_DURATION_MS;
          });
          var badge = document.getElementById('live-badge');
          if (!badge) return;
          if (isLive) {
            badge.classList.remove('hidden');
          } else {
            badge.classList.add('hidden');
          }
        }

        checkLive();
        setInterval(checkLive, 60000); // re-evalúa cada minuto
      })();
    </script>

    <!-- ── Script: Hora local del usuario ── -->
    <!--
      Todos los elementos con data-utc="<ISO>" se convierten al timezone del navegador.
      data-fmt puede ser: "time" | "date" | "datetime" (default: "time")
    -->
    <script is:inline>
      (function () {
        function formatLocal(isoStr, fmt) {
          try {
            const d = new Date(isoStr);
            if (isNaN(d)) return null;
            if (fmt === 'date-full') {
              const str = d.toLocaleDateString('es', {
                weekday: 'long', day: 'numeric', month: 'long'
              });
              return str.charAt(0).toUpperCase() + str.slice(1);
            }
            if (fmt === 'date') {
              return d.toLocaleDateString('es', {
                weekday: 'short', day: 'numeric', month: 'short'
              });
            }
            if (fmt === 'date-short') {
              return d.toLocaleDateString('es', {
                day: 'numeric', month: 'short'
              });
            }
            if (fmt === 'datetime') {
              return d.toLocaleDateString('es', {
                weekday: 'short', day: 'numeric', month: 'short'
              }) + ' · ' + d.toLocaleTimeString('es', {
                hour: 'numeric', minute: '2-digit', hour12: true
              });
            }
            // default: "time"
            return d.toLocaleTimeString('es', {
              hour: 'numeric', minute: '2-digit', hour12: true
            });
          } catch (e) {
            return null;
          }
        }

        function applyLocalTimes() {
          var counts = {};
          var elements = Array.from(document.querySelectorAll('[data-utc]'));
          
          // First pass: Calculate local strings and counts for date-full elements
          elements.forEach(function (el) {
            var iso = el.getAttribute('data-utc');
            var fmt = el.getAttribute('data-fmt') || 'time';
            var text = formatLocal(iso, fmt);
            el.__localText = text; // Cache it
            if (fmt === 'date-full' && text) {
              counts[text] = (counts[text] || 0) + 1;
            }
          });

          var lastDateText = null;

          // Second pass: Apply logic
          elements.forEach(function (el) {
            var fmt = el.getAttribute('data-fmt') || 'time';
            var text = el.__localText;
            if (text) {
              el.textContent = text;
              if (fmt === 'date-full') {
                var headerDiv = el.closest('.date-header-container');
                if (text === lastDateText) {
                  if (headerDiv) headerDiv.style.display = 'none';
                } else {
                  if (headerDiv) {
                    headerDiv.style.display = 'flex';
                    var countSpan = headerDiv.querySelector('.match-count');
                    if (countSpan) {
                      countSpan.textContent = counts[text] + (counts[text] === 1 ? ' partido' : ' partidos');
                    }
                  }
                  lastDateText = text;
                }
              }
            }
          });
        }

        // Ejecutar inmediatamente si el DOM ya cargó, si no esperar
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', applyLocalTimes);
        } else {
          applyLocalTimes();
        }
      })();
    </script>

    <!-- ── Script: Drag-to-scroll en carruseles (desktop) ── -->
    <script is:inline>
      (function () {
        function initCarousel(el) {
          var isDown  = false;
          var startX  = 0;
          var scrollL = 0;
          var moved   = false;

          el.style.cursor = 'grab';

          el.addEventListener('mousedown', function (e) {
            isDown  = true;
            moved   = false;
            startX  = e.pageX - el.offsetLeft;
            scrollL = el.scrollLeft;
            el.style.cursor = 'grabbing';
            el.style.userSelect = 'none';
          });

          el.addEventListener('mouseleave', function () {
            isDown = false;
            el.style.cursor = 'grab';
          });

          el.addEventListener('mouseup', function () {
            isDown = false;
            el.style.cursor = 'grab';
            el.style.userSelect = '';
          });

          el.addEventListener('mousemove', function (e) {
            if (!isDown) return;
            e.preventDefault();
            var x    = e.pageX - el.offsetLeft;
            var walk = (x - startX) * 1.2;
            if (Math.abs(walk) > 4) moved = true;
            el.scrollLeft = scrollL - walk;
          });

          // Evitar que un drag dispare clicks en los hijos
          el.addEventListener('click', function (e) {
            if (moved) { e.preventDefault(); e.stopPropagation(); moved = false; }
          }, true);
        }

        function setup() {
          document.querySelectorAll('.carousel-track').forEach(initCarousel);
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', setup);
        } else {
          setup();
        }
      })();
    </script>

