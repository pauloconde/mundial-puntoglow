---
import '../styles/global.css';
import { fetchWorldCupData, getMatchUTC } from '../lib/worldcup';
import sponsorInfo from '../data/sponsor.json';
// @ts-ignore
import { pwaInfo } from 'virtual:pwa-info';

interface Props {
  title?: string;
  description?: string;
  page?: 'home' | 'grupos' | 'estadios' | 'calendario';
}

const {
  title = sponsorInfo.seo.defaultTitle,
  description = sponsorInfo.seo.description,
  page = 'home'
} = Astro.props;

// Resolvemos el título final
const pageTitle = title === sponsorInfo.seo.defaultTitle
  ? sponsorInfo.seo.defaultTitle
  : sponsorInfo.seo.titleTemplate.replace('%s', title);

// Recoger todos los kickoffs para detección de partidos en vivo en el cliente
const data = await fetchWorldCupData();
const kickoffISOs = data.matches.map(m => getMatchUTC(m));
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="keywords" content={sponsorInfo.seo.keywords} />
    <meta name="theme-color" content={sponsorInfo.colors.appBg} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    { pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} /> }
    <title>{pageTitle}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={new URL(sponsorInfo.seo.ogImage, Astro.site || Astro.url).toString()} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(sponsorInfo.seo.ogImage, Astro.site || Astro.url).toString()} />

    <style is:global set:html={`
      :root {
        --brand-app-bg: ${sponsorInfo.colors.appBg};
        --brand-splash-bg: ${sponsorInfo.colors.splashBg};
        --brand-header-bg: ${sponsorInfo.colors.headerBg};
        --brand-header-text: ${sponsorInfo.colors.headerText};
        --brand-nav-bg: ${sponsorInfo.colors.navBg};
        --brand-nav-text: ${sponsorInfo.colors.navText};
        --brand-nav-icon: ${sponsorInfo.colors.navIcon};
        --brand-nav-icon-active: ${sponsorInfo.colors.navIconActive};
        --brand-drawer-bg: ${sponsorInfo.colors.drawerBg || sponsorInfo.colors.navBg};
      }
    `} />

    <!-- Capturar PWA Prompt tempranamente -->
    <script is:inline>
      window.deferredPrompt = null;
      window.addEventListener('beforeinstallprompt', function (e) {
        e.preventDefault();
        window.deferredPrompt = e;
        // Si el drawer ya está listo, mostrar el botón
        var section = document.getElementById('install-android');
        if (section) section.style.display = 'block';
      });
    </script>
  </head>

  <body class="bg-[#0a0e1a] text-white font-['Inter'] pb-24">

    <!-- ── Splash Screen ── -->
    <div
      id="splash"
      class="fixed inset-0 z-[9999] flex flex-col"
      style="background: var(--brand-splash-bg);"
    >
      <!-- Logo FIFA — centrado en el espacio disponible -->
      <div class="flex-1 flex items-center justify-center slide-up">
        <img src="/logo-fifa.webp" alt="FIFA World Cup 2026"
             class="w-72 max-w-[80vw] h-auto object-contain" />
      </div>

      <!-- Logo del sponsor — anclado al fondo con padding seguro -->
      <div class="flex justify-center pb-10" style="padding-bottom: max(2.5rem, env(safe-area-inset-bottom, 2.5rem));">
        <img src="/logo-splash.svg" alt="Sponsor"
             class="h-64 w-auto max-w-[60vw] object-contain" />
      </div>
    </div>

    <!-- ── Header ── -->
    <header class="app-header fixed top-0 left-0 right-0 z-50"
            style="padding-top: env(safe-area-inset-top, 0px);">
      <div class="flex items-center justify-between px-4 h-14">
        <!-- Logo del sponsor -->
        <a href="/" class="flex items-center" id="header-logo">
          <img src="/logo.webp" alt="Logo" class="h-8 w-auto max-w-[140px] object-contain" />
        </a>

        <div class="flex items-center gap-2">
          <!-- Badge LIVE -->
          <div id="live-badge"
               class="hidden flex items-center gap-1.5 px-2 py-1 rounded-full"
               style="background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.3);">
            <span class="live-dot"></span>
            <span class="text-[10px] font-bold text-red-400 tracking-wider">LIVE</span>
          </div>

          <!-- Botón abrir drawer -->
          <button id="drawer-open"
                  class="w-9 h-9 flex items-center justify-center rounded-full transition-colors"
                  style="color: var(--brand-nav-icon, #6b7280);"
                  aria-label="Menú">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </div>
      </div>
    </header>

    <!-- ── Drawer backdrop ── -->
    <div id="drawer-backdrop"
         class="fixed inset-0 z-[8000] bg-black/60 backdrop-blur-sm"
         style="display:none; opacity:0; transition: opacity 0.3s;"
         aria-hidden="true"></div>

    <!-- ── Drawer panel ── -->
    <aside id="drawer-panel"
           class="fixed top-0 right-0 bottom-0 z-[8001] w-80 max-w-[90vw] flex flex-col"
           style={`background: ${sponsorInfo.colors.drawerBg || sponsorInfo.colors.navBg || '#0a0e1a'}; border-left: 1px solid var(--border-subtle); transform: translateX(100%); transition: transform 0.35s cubic-bezier(0.4,0,0.2,1); padding-top: env(safe-area-inset-top, 0px);`}>

      <!-- Header del drawer -->
      <div class="flex items-center justify-between px-5 h-14 border-b"
           style="border-color: var(--border-subtle);">
        <span class="font-['Outfit'] font-bold text-sm" style="color: var(--brand-nav-text, #fff);">FIFA World Cup 2026</span>
        <button id="drawer-close" class="w-8 h-8 flex items-center justify-center rounded-full"
                style="color: var(--brand-nav-icon, #6b7280);" aria-label="Cerrar">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <!-- Contenido -->
      <div class="flex-1 overflow-y-auto px-5 py-6 flex flex-col gap-8">
        
        <!-- Logo Sponsor Grande -->
        <div class="flex flex-col items-center gap-5 mt-4">
